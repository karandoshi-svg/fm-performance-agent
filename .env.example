# PFM Weekly Agent — copy this to ~/.pfm-agent.env and fill in values
#
# OPTION A: Slack Incoming Webhook (simplest — no Slack app needed)
# Create at: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXX/BXXXXXXX/XXXXXXXX

# OPTION B: Slack Bot Token (requires app with chat:write scope)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=#pfm-ai-insights

# Optional overrides
# SUPERSET_BASE_URL=https://superset.robinhood.com
